{
  "name": "agents-registry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tooling and validation scripts for the Copilot Agents Registry.",
  "scripts": {
    "env:check": "tsx scripts/validate-env.ts",
    "package:validate": "tsx scripts/package-validate.ts",
    "package:build": "tsx scripts/package-build.ts",
    "package:validate-artifacts": "tsx scripts/package-validate-artifacts.ts",
    "package:scan-zips": "tsx scripts/package-scan-zips.ts",
    "package:index:rebuild": "tsx scripts/package-index-rebuild.ts",
    "package:create": "tsx scripts/package-create.ts",
    "package:create:smoke": "tsx scripts/package-create-smoke.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"**/.*/**/*.md\" \"!packages/**/versions/**\"",
    "lint:sonar": "eslint \"**/*.{ts,json,jsonc}\"",
    "lint:sonar:fix": "eslint \"**/*.{ts,json,jsonc}\" --fix",
    "lint:all": "npm run lint:md && npm run lint:sonar",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "24.15.0"
  },
  "packageManager": "npm@11.12.1",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.0.0",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "adm-zip": "^0.5.16",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "gray-matter": "^4.0.3",
    "husky": "^9",
    "jsonc-eslint-parser": "^3.1.0",
    "markdownlint-cli2": "^0.22.1",
    "semantic-release": "^25.0.3",
    "semver": "^7.6.3",
    "simple-git": "^3.36.0",
    "tsx": "^4.19.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.7"
  }
}
